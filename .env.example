# PostgreSQL
POSTGRES_DB=fayni_db
POSTGRES_USER=fayni_user
POSTGRES_PASSWORD=change-me-demo-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql://fayni_user:change-me-demo-password@db:5432/fayni_db
SECRET_KEY=change-this-secret-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# pgAdmin
PGADMIN_EMAIL=demo.admin@fayni.app
PGADMIN_PASSWORD=change-me-pgadmin-password
